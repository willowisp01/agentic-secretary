# Copy this file to .env and fill in real values. Never commit .env itself.

# Anthropic API key (https://console.anthropic.com/)
ANTHROPIC_API_KEY=

# LangSmith API key for tracing (https://smith.langchain.com/)
LANGSMITH_API_KEY=

# Set to "true" to enable tracing -- without this, LANGSMITH_API_KEY alone
# does nothing.
LANGSMITH_TRACING=true

# Project name traces are grouped under in the LangSmith dashboard
LANGSMITH_PROJECT=agentic-secretary

# LangSmith API endpoint -- only needed for self-hosted or region-specific
# (e.g. EU) deployments; omit to use the default SaaS endpoint.
LANGSMITH_ENDPOINT=

# Path to the Google OAuth client secret JSON (downloaded from Google Cloud Console)
GOOGLE_CLIENT_SECRET_PATH=credentials.json

# Path where the cached Google OAuth user token will be stored after first login
GOOGLE_TOKEN_PATH=token.json

# Claude model used by the agent (defaults to claude-haiku-4-5 if unset)
MODEL_NAME=claude-haiku-4-5

# OpenAI API key, used only for embeddings (https://platform.openai.com/api-keys)
# -- Claude remains the only LLM used for reasoning/generation
OPENAI_API_KEY=

# Embedding model for the policy corpus (defaults to text-embedding-3-small
# if unset)
EMBEDDING_MODEL_NAME=text-embedding-3-small

# Chroma Cloud credentials (https://trychroma.com/ -- create an account,
# tenant, and database first)
CHROMA_API_KEY=
CHROMA_TENANT=
CHROMA_DATABASE=

# Local BGE cross-encoder reranker model, downloaded from Hugging Face on
# first use -- no API key needed (defaults to BAAI/bge-reranker-v2-m3 if
# unset)
RERANKER_MODEL_NAME=BAAI/bge-reranker-v2-m3

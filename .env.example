# Copy this file to .env and fill in real values. Never commit .env itself.

# Anthropic API key (https://console.anthropic.com/)
ANTHROPIC_API_KEY=

# LangSmith API key for tracing (https://smith.langchain.com/)
LANGSMITH_API_KEY=

# Path to the Google OAuth client secret JSON (downloaded from Google Cloud Console)
GOOGLE_CLIENT_SECRET_PATH=credentials.json

# Path where the cached Google OAuth user token will be stored after first login
GOOGLE_TOKEN_PATH=token.json

# Claude model used by the agent (defaults to claude-haiku-4-5 if unset)
MODEL_NAME=claude-haiku-4-5
